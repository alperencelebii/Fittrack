rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net: default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isMyCoach(athleteId) {
      return isSignedIn() && 
             get(/databases/$(database)/documents/users/$(athleteId)).data.get('coachId', null) == request.auth.uid;
    }

    // 1. Users Collection
    match /users/{userId} {
      // Own profile read
      allow read: if isOwner(userId);

      // Coach profiles are public/readable to enable invitation checks and verified connections
      allow read: if resource.data.get('role', 'athlete') == "coach";

      // Coaches can read their linked athletes' profiles
      allow read: if isSignedIn() && isMyCoach(userId);
      
      // Users can create/update own profiles
      allow create, update: if isOwner(userId);
    }

    // 2. Workouts Collection
    match /workouts/{workoutId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isMyCoach(resource.data.userId));
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // 3. WeightEntries Collection
    match /weightEntries/{weightId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isMyCoach(resource.data.userId));
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // 4. BodyMeasurements Collection
    match /bodyMeasurements/{measurementId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isMyCoach(resource.data.userId));
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // 5. MealEntries Collection
    match /mealEntries/{mealId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isMyCoach(resource.data.userId));
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // 6. WaterEntries Collection
    match /waterEntries/{waterId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isMyCoach(resource.data.userId));
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // 7. CoachNotes Collection
    match /coachNotes/{noteId} {
      allow read: if isSignedIn() && (resource.data.athleteId == request.auth.uid || resource.data.coachId == request.auth.uid);
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.coachId && isMyCoach(request.resource.data.athleteId);
      allow update: if isSignedIn() && request.auth.uid == request.resource.data.coachId && request.auth.uid == resource.data.coachId;
      allow delete: if isSignedIn() && request.auth.uid == resource.data.coachId;
    }

    // 8. CoachGoals Collection
    match /coachGoals/{goalId} {
      allow read: if isSignedIn() && (resource.data.athleteId == request.auth.uid || resource.data.coachId == request.auth.uid);
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.coachId && isMyCoach(request.resource.data.athleteId);
      allow update: if isSignedIn() && (request.auth.uid == resource.data.coachId || request.auth.uid == resource.data.athleteId);
      allow delete: if isSignedIn() && request.auth.uid == resource.data.coachId;
    }

    // 9. CoachAthleteRelations Collection
    match /coachAthleteRelations/{relationId} {
      allow read: if isSignedIn() && (resource.data.athleteId == request.auth.uid || resource.data.coachId == request.auth.uid);
      
      // Create/Delete relation document
      allow create, delete: if isSignedIn();
    }
  }
}